{
  "name": "order-hub-backend",
  "version": "0.1.0",
  "description": "Order Hub - Multi-platform order aggregation API",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "db:migrate": "node -e \"require('./src/db-postgres').migrate().then(() => process.exit(0))\"",
    "db:import": "node -e \"require('./src/db-postgres').importFromLowDB().then(() => process.exit(0))\"",
    "db:rollback": "node -e \"require('./src/db-postgres').rollback().then(() => process.exit(0))\"",
    "db:check": "node -e \"require('./src/db-postgres').checkConnection().then(() => process.exit(0))\""
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/multipart": "^8.0.0",
    "dotenv": "^16.4.1",
    "fastify": "^4.26.0",
    "lowdb": "^7.0.1",
    "pg": "^8.20.0",
    "uuid": "^9.0.1",
    "xlsx": "^0.18.5"
  }
}
